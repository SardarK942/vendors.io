{
  "name": "baazar.io",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:unit": "vitest run --dir src/__tests__",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "scrape:hand-curated": "tsx scripts/scraper/sources/hand-curated.ts",
    "scrape:google-maps": "tsx scripts/scraper/sources/google-maps.ts",
    "scrape:catering": "tsx scripts/scraper/sources/il-desi-arab-catering.ts",
    "scrape:tiktok": "tsx scripts/scraper/sources/tiktok.ts",
    "scrape:merge": "tsx scripts/scraper/merge.ts",
    "scrape:mint-tokens": "tsx scripts/scraper/mint-tokens.ts",
    "scrape:instagram:hashtags": "tsx -e \"import('./scripts/scraper/sources/instagram.ts').then(m => (m.default || m).runInstagramHashtagLayer({ category: process.env.SCRAPE_CATEGORY || 'carts' }))\"",
    "scrape:instagram:locations": "tsx -e \"import('./scripts/scraper/sources/instagram.ts').then(m => (m.default || m).runInstagramLocationLayer())\"",
    "scrape:instagram:expand": "tsx -e \"import('./scripts/scraper/sources/instagram.ts').then(m => (m.default || m).runInstagramProfileExpansion(new Date().toISOString().slice(0,10)))\"",
    "scrape:instagram:bio": "tsx -e \"import('./scripts/scraper/sources/instagram.ts').then(m => (m.default || m).runInstagramBioSearch())\"",
    "scrape:instagram:combine": "tsx -e \"import('./scripts/scraper/sources/instagram.ts').then(m => (m.default || m).combineInstagramLayers(new Date().toISOString().slice(0,10)))\"",
    "scrape:searchgraph": "tsx scripts/scraper/sources/searchgraph.ts",
    "scrape:rehost-photos": "tsx scripts/scraper/rehost-photos.ts",
    "curate:lookup": "tsx --env-file-if-exists=.env.local scripts/curate/add-vendor.ts lookup",
    "curate:insert": "tsx --env-file-if-exists=.env.local scripts/curate/add-vendor.ts insert",
    "curate:batch-lookup": "tsx --env-file-if-exists=.env.local scripts/curate/batch-lookup.ts",
    "curate:batch-insert": "tsx --env-file-if-exists=.env.local scripts/curate/batch-insert.ts",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.96.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google/generative-ai": "^0.24.1",
    "@googlemaps/google-maps-services-js": "^3.4.2",
    "@googlemaps/js-api-loader": "^2.0.2",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@radix-ui/react-use-controllable-state": "^1.2.2",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.9",
    "@sentry/nextjs": "^10.49.0",
    "@stripe/stripe-js": "^8.7.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.95.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@uploadthing/react": "^7.3.3",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "apify-client": "^2.23.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "ics": "^3.12.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.564.0",
    "next": "14.2.35",
    "next-themes": "^0.4.6",
    "openai": "^6.22.0",
    "react": "^18",
    "react-day-picker": "^10.0.1",
    "react-dom": "^18",
    "react-hook-form": "^7.71.1",
    "resend": "^6.9.2",
    "sonner": "^2.0.7",
    "stripe": "^20.3.1",
    "tailwind-merge": "^3.4.1",
    "tailwindcss-animate": "^1.0.7",
    "uploadthing": "^7.7.4",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^16.2.7",
    "playwright": "^1.60.0",
    "postcss": "^8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.22.3",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
